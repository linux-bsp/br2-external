config BR2_PACKAGE_PAF
	bool "paf"
	depends on BR2_LINUX_KERNEL
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_MMU
	help
	  PAF is a Linux peripheral access framework with a
	  Kconfig+CMake/Kbuild build system. It provides the PDM kernel
	  module, the shared PDI userspace library, UAPI headers, and
	  optional PDI tools such as pdebug and pdi_claim_test.

if BR2_PACKAGE_PAF

config BR2_PACKAGE_PAF_DEFCONFIG
	string "Kconfig defconfig to use"
	default ""
	help
	  Specify which PAF defconfig to load before building.
	  Product external trees should set this to a product-specific
	  PAF defconfig, for example imx6ull_modules_defconfig. Debug
	  images should use a defconfig that enables CONFIG_PDI,
	  CONFIG_PDEBUG, and CONFIG_PDI_CLAIM_TEST when board-side claim
	  validation is required.

config BR2_PACKAGE_PAF_PDI_BMC_REDFISH
	bool "Enable PAF PDI BMC Redfish dependencies"
	select BR2_PACKAGE_CJSON
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_FORCE_TLS
	select BR2_PACKAGE_LIBCURL_OPENSSL
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_OPENSSL_FORCE_LIBOPENSSL
	help
	  Select this when the PAF defconfig enables CONFIG_PDI_BMC_REDFISH.
	  It provides libcurl and cJSON for the Redfish backend in libpdi.so.

config BR2_PACKAGE_PAF_PDI_BMC_IPMI
	bool "Enable PAF PDI BMC IPMI dependencies"
	select BR2_PACKAGE_FREEIPMI
	select BR2_PACKAGE_LIBGCRYPT if BR2_PACKAGE_LIBGPG_ERROR_ARCH_SUPPORTS
	help
	  Select this when the PAF defconfig enables CONFIG_PDI_BMC_IPMI.
	  It provides libfreeipmi for the IPMI backend in libpdi.so.
	  libgcrypt is selected when available so FreeIPMI can support IPMI 2.0
	  RMCP+ network sessions.

config BR2_PACKAGE_PAF_TB_MQTT_PUB
	bool "Enable PAF ThingsBoard MQTT app dependencies"
	depends on !BR2_STATIC_LIBS
	select BR2_PACKAGE_MOSQUITTO
	help
	  Select this when the PAF defconfig enables CONFIG_TB_MQTT_PUB.
	  It provides libmosquitto for the tb_mqtt_pub telemetry publisher.

config BR2_PACKAGE_PAF_FWCTL
	bool "Enable PAF firmware update app dependencies"
	depends on !BR2_STATIC_LIBS
	select BR2_PACKAGE_CA_CERTIFICATES
	select BR2_PACKAGE_DTC
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_FORCE_TLS
	select BR2_PACKAGE_LIBCURL_OPENSSL
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_OPENSSL_FORCE_LIBOPENSSL
	help
	  Select this when the PAF defconfig enables CONFIG_FWCTL. It provides
	  libfdt, libcurl, and OpenSSL for FIT parsing, HTTP(S) downloads, and
	  SHA-256 verification.

config BR2_PACKAGE_PAF_FWCTL_FIT_SIGNATURE
	bool "Install fwctl FIT signature verifier"
	depends on BR2_PACKAGE_PAF_FWCTL
	select BR2_PACKAGE_UBOOT_TOOLS
	select BR2_PACKAGE_UBOOT_TOOLS_FIT_SUPPORT
	select BR2_PACKAGE_UBOOT_TOOLS_FIT_SIGNATURE_SUPPORT
	select BR2_PACKAGE_UBOOT_TOOLS_FIT_CHECK_SIGN
	help
	  Install fit_check_sign for fwctl configurations that require FIT
	  signature verification against a trusted key DTB.


choice
	prompt "Build type"
	default BR2_PACKAGE_PAF_BUILD_TYPE_RELEASE

config BR2_PACKAGE_PAF_BUILD_TYPE_RELEASE
	bool "Release"

config BR2_PACKAGE_PAF_BUILD_TYPE_DEBUG
	bool "Debug"

config BR2_PACKAGE_PAF_BUILD_TYPE_RELWITHDEBINFO
	bool "RelWithDebInfo"

endchoice

config BR2_PACKAGE_PAF_BUILD_TYPE
	string
	default "Release" if BR2_PACKAGE_PAF_BUILD_TYPE_RELEASE
	default "Debug" if BR2_PACKAGE_PAF_BUILD_TYPE_DEBUG
	default "RelWithDebInfo" if BR2_PACKAGE_PAF_BUILD_TYPE_RELWITHDEBINFO

config BR2_PACKAGE_PAF_INSTALL_HEADERS
	bool "Install development headers"
	default n
	help
	  Install development headers to $(STAGING_DIR)/usr/include/pdm/.
	  Only needed for packages that depend on PAF.

endif # BR2_PACKAGE_PAF

comment "PAF needs Linux kernel and a toolchain w/ threads, MMU"
	depends on !BR2_LINUX_KERNEL || !BR2_TOOLCHAIN_HAS_THREADS || \
		!BR2_USE_MMU
