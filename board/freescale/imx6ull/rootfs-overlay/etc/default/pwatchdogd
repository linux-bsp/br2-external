# pwatchdogd runtime configuration

# Set to 0 to keep the service installed but disabled at boot.
ENABLED=1

WATCHDOG_PATH=/dev/watchdog0
WATCHDOG_TIMEOUT_SEC=10
MCU_NAME=main_mcu
INTERVAL_MS=1000

USE_WATCHDOG=1
USE_HEARTBEAT=1
DISABLE_ON_EXIT=0

# Extra arguments appended to pwatchdogd.
EXTRA_ARGS=
