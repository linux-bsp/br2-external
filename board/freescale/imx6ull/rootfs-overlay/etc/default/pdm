# PDM default configuration
# Override CAN settings by setting environment variables in this file

# CAN interface name (default: can0)
#CAN_IFACE=can0

# CAN bitrate in bps (default: 500000)
#CAN_BITRATE=500000

# Enable CAN FD (default: 0)
#CAN_FD=0

# CAN FD data bitrate in bps (default: 2000000)
#CAN_DBITRATE=2000000

# CAN auto-restart delay in ms (default: 100)
#CAN_RESTART_MS=100
