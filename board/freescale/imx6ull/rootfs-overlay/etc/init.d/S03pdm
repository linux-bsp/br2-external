#!/bin/sh
#
# S03pdm - PDM framework initialization
#

PATH=/sbin:/bin:/usr/sbin:/usr/bin

NAME="S03pdm"
MODULES="pdm"

# CAN configuration (overridable via /etc/default/pdm)
CAN_IFACE="${CAN_IFACE:-can0}"
CAN_BITRATE="${CAN_BITRATE:-500000}"
CAN_FD="${CAN_FD:-0}"
CAN_DBITRATE="${CAN_DBITRATE:-2000000}"
CAN_RESTART_MS="${CAN_RESTART_MS:-100}"

# Load optional configuration
[ -r /etc/default/pdm ] && . /etc/default/pdm

log()
{
    echo "[$NAME] $*"
}

module_loaded()
{
    grep -qw "^$1" /proc/modules
}

can_available()
{
    [ -d "/sys/class/net/$CAN_IFACE" ]
}

can_fd_enabled()
{
    case "$CAN_FD" in
        1|y|Y|yes|YES|true|TRUE|on|ON)
            return 0
            ;;
    esac
    return 1
}

setup_can()
{
    can_available || return 1

    ip link set "$CAN_IFACE" down 2>/dev/null || true

    if can_fd_enabled; then
        ip link set "$CAN_IFACE" type can \
            bitrate "$CAN_BITRATE" \
            dbitrate "$CAN_DBITRATE" \
            fd on \
            restart-ms "$CAN_RESTART_MS" || return 1
        log "$CAN_IFACE configured: bitrate=$CAN_BITRATE dbitrate=$CAN_DBITRATE fd=on"
    else
        ip link set "$CAN_IFACE" type can \
            bitrate "$CAN_BITRATE" \
            restart-ms "$CAN_RESTART_MS" || return 1
        log "$CAN_IFACE configured: bitrate=$CAN_BITRATE"
    fi

    if ip link set "$CAN_IFACE" up; then
        log "$CAN_IFACE up"
        return 0
    fi

    log "failed to bring up $CAN_IFACE"
    return 1
}

load_module()
{
    local module="$1"

    if module_loaded "$module"; then
        log "$module already loaded"
        return 0
    fi

    if modprobe "$module"; then
        log "$module loaded"
        return 0
    fi

    log "failed to load $module"
    return 1
}

start()
{
    # Configure CAN if available
    can_available && setup_can

    # Load PDM module
    load_module pdm
}

stop()
{
    :
}

status()
{
    if can_available; then
        ip -details link show "$CAN_IFACE"
    fi

    if module_loaded pdm; then
        echo "pdm: loaded"
    else
        echo "pdm: not loaded"
    fi
}

case "$1" in
    start|"")
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        stop
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac

exit $?
