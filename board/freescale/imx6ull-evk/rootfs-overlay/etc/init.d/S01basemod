#!/bin/sh

PATH=/sbin:/bin:/usr/sbin:/usr/bin

NAME="S01basemod"
ETH1_ADDR="192.168.18.241"
ETH1_NETMASK="255.255.255.0"

log()
{
    echo "[$NAME] $*"
}

is_mounted()
{
    grep -qs "[[:space:]]$1[[:space:]]" /proc/mounts
}

mount_fs()
{
    local type="$1"
    local source="$2"
    local target="$3"

    mkdir -p "$target"

    if is_mounted "$target"; then
        log "$target already mounted"
        return 0
    fi

    if mount -t "$type" "$source" "$target"; then
        log "mounted $target"
        return 0
    fi

    log "failed to mount $target"
    return 1
}

init_ftrace()
{
    if grep -qw debugfs /proc/filesystems; then
        mount_fs debugfs debugfs /sys/kernel/debug
    else
        log "debugfs is not supported by this kernel"
    fi

    if grep -qw tracefs /proc/filesystems; then
        mount_fs tracefs tracefs /sys/kernel/tracing
        mount_fs tracefs tracefs /sys/kernel/debug/tracing
    else
        log "tracefs is not supported by this kernel"
    fi
}

init_eth1()
{
    if [ ! -d /sys/class/net/eth1 ]; then
        log "eth1 not found, skip network initialization"
        return 0
    fi

    mkdir -p /var/run

    if ifup eth1; then
        log "eth1 initialized"
        return 0
    fi

    log "ifup eth1 failed, configure static address directly"
    if ifconfig eth1 "$ETH1_ADDR" netmask "$ETH1_NETMASK" up; then
        log "eth1 configured as $ETH1_ADDR/$ETH1_NETMASK"
        return 0
    fi

    log "failed to initialize eth1"
    return 1
}

start()
{
    log "base module initialization"

    init_ftrace
    init_eth1

    log "system ready"
}

stop()
{
    if [ -d /sys/class/net/eth1 ]; then
        ifdown eth1 2>/dev/null || true
    fi
}

case "$1" in
    start|"")
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        stop
        start
        ;;
    status)
        [ -d /sys/class/net/eth1 ] && echo "eth1: present" || echo "eth1: absent"
        is_mounted /sys/kernel/tracing && echo "tracefs: mounted" || echo "tracefs: not mounted"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac
