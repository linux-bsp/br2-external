#!/bin/sh

[ -r /etc/default/fwctl ] && . /etc/default/fwctl

case "$1" in
	start)
		[ "${AUTO_MARK_GOOD:-0}" = "1" ] || exit 0
		grep -q 'fw\.deployment=[01]' /proc/cmdline || exit 0
		if [ -n "${FWCTL_HEALTHCHECK:-}" ] &&
		   ! sh -c "${FWCTL_HEALTHCHECK}"; then
			echo "fwctl: health check failed; deployment remains pending" >&2
			exit 1
		fi
		if /usr/sbin/fwctl \
			--config "${FWCTL_CONFIG:-/etc/fwctl.conf}" \
			mark-good; then
			echo "fwctl: current deployment marked good"
		else
			echo "fwctl: failed to confirm current deployment" >&2
			exit 1
		fi
		;;
	stop|restart|reload)
		;;
	*)
		echo "Usage: $0 {start|stop|restart|reload}" >&2
		exit 2
		;;
esac

exit 0
