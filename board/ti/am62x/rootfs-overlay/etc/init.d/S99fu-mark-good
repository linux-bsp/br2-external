#!/bin/sh

[ -r /etc/default/fuctl ] && . /etc/default/fuctl

case "$1" in
	start)
		[ "${AUTO_MARK_GOOD:-0}" = "1" ] || exit 0
		grep -q 'fu\.deployment=[01]' /proc/cmdline || exit 0
		if [ -n "${FUCTL_HEALTHCHECK:-}" ] &&
		   ! sh -c "${FUCTL_HEALTHCHECK}"; then
			echo "fuctl: health check failed; deployment remains pending" >&2
			exit 1
		fi
		if /usr/sbin/fuctl \
			--device "${FUCTL_DEVICE:-/dev/mmcblk1}" \
			--meta0 "${FUCTL_META0:-0x00500000}" \
			--meta1 "${FUCTL_META1:-0x00510000}" \
			mark-good; then
			echo "fuctl: current deployment marked good"
		else
			echo "fuctl: failed to confirm current deployment" >&2
			exit 1
		fi
		;;
	stop|restart|reload)
		;;
	*)
		echo "Usage: $0 {start|stop|restart|reload}" >&2
		exit 2
		;;
esac

exit 0
