menu "H200 100P AM625 Board Configuration"

choice
	prompt "Device Tree Selection"
	default BR2_H200_DTB_SK
	help
	  Select which device tree to use for this board.

config BR2_H200_DTB_SK
	bool "k3-am625-sk (Standard Version)"
	help
	  Use the standard k3-am625-sk device tree.
	  This is the default device tree configuration.

config BR2_H200_DTB_3RD
	bool "k3-am625-3rd (Third Party Version)"
	help
	  Use the k3-am625-3rd device tree.
	  This is an alternative device tree configuration.

endchoice
endmenu
