#!/bin/sh

# 挂载 devtmpfs 以获得 /dev/console
/bin/mount -t devtmpfs none /dev

exec 0>/dev/console 1>/dev/console 2>/dev/console

# 现在可以输出到控制台了
/bin/echo "=== Custom init starting ==="

# 挂载其他文件系统
/bin/mount -t proc none /proc
/bin/mount -t sysfs none /sys

/bin/echo "[init] Mounted proc, sys, dev"

# 显示系统信息
/bin/echo "[init] Kernel version:"
/bin/cat /proc/version

# 执行启动脚本
if [ -x /etc/init.d/rcS ]; then
    /bin/echo "[init] Running rcS..."
    /etc/init.d/rcS
fi

# 启动 shell
/bin/echo "=== Init complete, starting shell ==="
exec /bin/sh < /dev/console
